// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum PaymentMethodType {
  CARD
  CASH
}

enum FortnightPeriod {
  FIRST // 1–15
  SECOND // 16–end of month
}

enum HouseRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  active   Boolean @default(true)
  email    String  @unique
  password String

  created_at DateTime @default(now())

  // Relationships
  income           FortnightIncome[]
  income_templates IncomeTemplate[]
  memberships      HouseMember[]
  houses           House[]
}

model Fortnight {
  id         Int             @id @default(autoincrement())
  start_date DateTime
  end_date   DateTime
  label      String
  month      Int
  year       Int
  period     FortnightPeriod
  closed     Boolean         @default(false)

  house_id Int?

  created_at DateTime @default(now())

  // Relationships
  expenses Expense[]
  income   FortnightIncome[]
  house    House?            @relation(fields: [house_id], references: [id])
}

model PaymentMethod {
  id   Int               @id @default(autoincrement())
  name String            @unique
  type PaymentMethodType

  created_at DateTime @default(now())

  // Relationships
  cards Card[]
}

model Card {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  cutoff_day  Int?
  due_day     Int?
  active      Boolean @default(true)

  payment_method_id Int
  house_id          Int?

  created_at DateTime @default(now())

  // Relationships
  expenses          Expense[]
  expense_templates ExpenseTemplate[]
  payment_method    PaymentMethod     @relation(fields: [payment_method_id], references: [id])
  house             House?            @relation(fields: [house_id], references: [id])
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  created_at DateTime @default(now())

  // Relationships
  expenses          Expense[]
  expense_templates ExpenseTemplate[]
}

model ExpenseTemplate {
  id                       Int      @id @default(autoincrement())
  name                     String
  suggested_amount         Decimal? @db.Decimal(10, 2)
  is_recurring             Boolean  @default(false)
  applies_first_fortnight  Boolean  @default(false)
  applies_second_fortnight Boolean  @default(false)
  is_subscription          Boolean  @default(false)
  due_day                  Int?
  cutoff_day               Int?
  active                   Boolean  @default(true)

  category_id     Int?
  default_card_id Int?
  house_id        Int?

  created_at DateTime @default(now())

  // Relationships
  expenses     Expense[]
  category     Category? @relation(fields: [category_id], references: [id])
  default_card Card?     @relation(fields: [default_card_id], references: [id])
  house        House?    @relation(fields: [house_id], references: [id])
}

model Expense {
  id           Int       @id @default(autoincrement())
  description  String
  amount       Decimal   @db.Decimal(10, 2)
  is_paid      Boolean   @default(false)
  payment_date DateTime?
  due_day      Int?

  house_id            Int?
  fortnight_id        Int
  card_id             Int?
  category_id         Int
  expense_template_id Int?

  created_at DateTime @default(now())

  // Relationships
  fortnight        Fortnight        @relation(fields: [fortnight_id], references: [id])
  card             Card?            @relation(fields: [card_id], references: [id])
  category         Category         @relation(fields: [category_id], references: [id])
  expense_template ExpenseTemplate? @relation(fields: [expense_template_id], references: [id])
  house            House?           @relation(fields: [house_id], references: [id])
}

model FortnightIncome {
  id           Int     @id @default(autoincrement())
  amount       Decimal @db.Decimal(10, 2)
  source       String?
  is_deduction Boolean @default(false)
  related_loan String?

  fortnight_id        Int
  user_id             Int
  house_id            Int
  income_template_id  Int?

  created_at DateTime @default(now())

  // Relationships
  fortnight       Fortnight      @relation(fields: [fortnight_id], references: [id])
  user            User           @relation(fields: [user_id], references: [id])
  house           House          @relation(fields: [house_id], references: [id])
  income_template IncomeTemplate? @relation(fields: [income_template_id], references: [id])
}

model IncomeTemplate {
  id                       Int      @id @default(autoincrement())
  name                     String
  suggested_amount         Decimal? @db.Decimal(10, 2)
  source                   String?
  applies_first_fortnight  Boolean  @default(false)
  applies_second_fortnight Boolean  @default(false)
  active                   Boolean  @default(true)

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())

  // Relationships
  fortnight_incomes FortnightIncome[]
  user              User?  @relation(fields: [user_id], references: [id])
  house             House? @relation(fields: [house_id], references: [id])
}

model House {
  id       Int    @id @default(autoincrement())
  name     String
  owner_id Int?

  created_at DateTime @default(now())

  // Relationships
  members          HouseMember[]
  fortnights       Fortnight[]
  expenses         Expense[]
  expenseTemplates  ExpenseTemplate[]
  incomeTemplates  IncomeTemplate[]
  cards            Card[]
  incomes          FortnightIncome[]
  owner            User?             @relation(fields: [owner_id], references: [id])
}

model HouseMember {
  id       Int       @id @default(autoincrement())
  house_id Int
  user_id  Int
  role     HouseRole

  created_at DateTime @default(now())

  // Relationships
  house House @relation(fields: [house_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id])
}
