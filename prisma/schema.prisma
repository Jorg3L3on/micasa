// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum PaymentMethodType {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  DEPARTMENT_STORE_CARD
}

enum FortnightPeriod {
  FIRST // 1–15
  SECOND // 16–end of month
}

enum HouseRole {
  OWNER
  ADMIN
  MEMBER
}

enum TransferType {
  USER_TO_HOUSE
}

enum BudgetFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  CUSTOM
}

enum StatementImportProvider {
  MERCADO_PAGO
  CA_DEPARTAMENTAL
  CA_EFECTIVO
}

enum ShoppingCartStatus {
  IN_PROGRESS
  BOUGHT
  CANCELED
  ARCHIVED
}

enum ShoppingCartActivityAction {
  CART_CREATED
  CART_UPDATED
  CART_STATUS_CHANGED
  CART_DELETED
  ITEM_ADDED
  ITEM_UPDATED
  ITEM_CHECKED
  ITEM_UNCHECKED
  ITEM_REMOVED
}

enum ShoppingStore {
  BODEGA_AURRERA
  SORIANA
  CHEDRAUI
  WALMART
  SAMS_CLUB
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum RecurrenceUnit {
  DAY
  WEEK
  MONTH
}

enum RoutineTimeOfDay {
  MORNING
  AFTERNOON
  NIGHT
  CUSTOM
}

model User {
  id                   Int     @id @default(autoincrement())
  name                 String
  email                String  @unique
  password             String
  active               Boolean @default(true)
  onboarding_completed Boolean @default(false)

  created_at DateTime @default(now())

  // Personal finance
  fortnights         Fortnight[]
  incomes            Income[]
  expenses           Expense[]
  expenseTemplates   ExpenseTemplate[]
  incomeTemplates    IncomeTemplate[]
  wallets            Wallet[]
  categories         Category[]
  creditCardPayments CreditCardPayment[]
  budgets            Budget[]

  credit_card_statement_imports_created CreditCardStatementImport[] @relation("CreditCardStatementImportCreatedBy")
  credit_card_statement_imports_owned   CreditCardStatementImport[] @relation("CreditCardStatementImportUserOwner")

  pantry_receipts_created PantryReceipt[] @relation("PantryReceiptCreatedBy")
  pantry_receipts_owned   PantryReceipt[] @relation("PantryReceiptUserOwner")
  pantry_products         PantryProduct[] @relation("PantryProductUserOwner")

  pantry_shopping_carts_owned   PantryShoppingCart[]         @relation("PantryShoppingCartUserOwner")
  pantry_shopping_carts_created PantryShoppingCart[]         @relation("PantryShoppingCartCreatedBy")
  pantry_shopping_carts_updated PantryShoppingCart[]         @relation("PantryShoppingCartUpdatedBy")
  pantry_shopping_items_created PantryShoppingCartItem[]     @relation("PantryShoppingCartItemCreatedBy")
  pantry_shopping_items_updated PantryShoppingCartItem[]     @relation("PantryShoppingCartItemUpdatedBy")
  pantry_shopping_activities    PantryShoppingCartActivity[] @relation("PantryShoppingCartActivityUser")
  task_lists_owned              TaskList[]                   @relation("TaskListUserOwner")
  tasks_created                 TaskItem[]                   @relation("TaskItemCreatedBy")
  habits_owned                  Habit[]                      @relation("HabitUserOwner")
  habit_logs_completed          HabitLog[]                   @relation("HabitLogCompletedBy")
  routines_owned                Routine[]                    @relation("RoutineUserOwner")
  routine_runs_completed        RoutineRun[]                 @relation("RoutineRunCompletedBy")

  // Shared
  memberships HouseMember[]
  ownedHouses House[]
  transfers   Transfer[]
}

model Fortnight {
  id         Int             @id @default(autoincrement())
  start_date DateTime
  end_date   DateTime
  label      String
  month      Int
  year       Int
  period     FortnightPeriod
  closed     Boolean         @default(false)

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())

  // Relationships
  house House? @relation(fields: [house_id], references: [id])
  user  User?  @relation(fields: [user_id], references: [id])

  expenses Expense[]
  incomes  Income[]

  @@unique([user_id, month, year, period])
  @@unique([house_id, month, year, period])
  @@index([user_id])
  @@index([house_id])
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())

  // Relationships
  user               User?              @relation(fields: [user_id], references: [id])
  house              House?             @relation(fields: [house_id], references: [id])
  expenses           Expense[]
  expense_templates  ExpenseTemplate[]
  budget_allocations BudgetAllocation[]

  @@index([user_id])
  @@index([house_id])
}

model ExpenseTemplate {
  id                       Int      @id @default(autoincrement())
  name                     String
  suggested_amount         Decimal? @db.Decimal(10, 2)
  is_recurring             Boolean  @default(false)
  applies_first_fortnight  Boolean  @default(false)
  applies_second_fortnight Boolean  @default(false)
  is_subscription          Boolean  @default(false)
  due_day                  Int?
  due_day_first_fortnight  Int?
  due_day_second_fortnight Int?
  cutoff_day               Int?
  active                   Boolean  @default(true)

  category_id Int?
  house_id    Int?
  user_id     Int?
  wallet_id   Int?

  created_at DateTime @default(now())

  // Relationships
  expenses Expense[]
  category Category? @relation(fields: [category_id], references: [id])
  house    House?    @relation(fields: [house_id], references: [id])
  user     User?     @relation(fields: [user_id], references: [id])
  wallet   Wallet?   @relation(fields: [wallet_id], references: [id])

  @@index([user_id])
  @@index([house_id])
}

model Expense {
  id           Int       @id @default(autoincrement())
  description  String
  amount       Decimal   @db.Decimal(10, 2)
  is_paid      Boolean   @default(false)
  payment_date DateTime?
  due_day      Int?

  /// Cuotas en meses (installment): cuota actual y total (ej. 11 de 15). Null = no aplica.
  credit_installment_current Int?
  credit_installment_total   Int?

  house_id            Int?
  fortnight_id        Int
  category_id         Int?
  expense_template_id Int?
  user_id             Int?
  wallet_id           Int?

  created_at DateTime @default(now())

  // Relationships
  fortnight        Fortnight        @relation(fields: [fortnight_id], references: [id])
  user             User?            @relation(fields: [user_id], references: [id])
  wallet           Wallet?          @relation(fields: [wallet_id], references: [id])
  category         Category?        @relation(fields: [category_id], references: [id])
  expense_template ExpenseTemplate? @relation(fields: [expense_template_id], references: [id])
  house            House?           @relation(fields: [house_id], references: [id])

  statement_import_id Int?
  statement_import    CreditCardStatementImport? @relation(fields: [statement_import_id], references: [id], onDelete: SetNull)

  transferAsUser      Transfer?          @relation("TransferUserExpense")
  credit_card_payment CreditCardPayment?

  @@index([user_id])
  @@index([house_id])
  @@index([fortnight_id])
  @@index([wallet_id])
  @@index([expense_template_id])
  @@index([statement_import_id])
}

model Income {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(10, 2)
  source      String?
  received_at DateTime

  user_id            Int?
  house_id           Int?
  fortnight_id       Int
  income_template_id Int?
  wallet_id          Int?
  created_at         DateTime @default(now())

  // Relationships
  fortnight       Fortnight       @relation(fields: [fortnight_id], references: [id])
  user            User?           @relation(fields: [user_id], references: [id])
  income_template IncomeTemplate? @relation(fields: [income_template_id], references: [id])
  house           House?          @relation(fields: [house_id], references: [id])
  wallet          Wallet?         @relation(fields: [wallet_id], references: [id])

  transferAsHouse Transfer? @relation("TransferHouseIncome")

  @@index([user_id])
  @@index([house_id])
  @@index([fortnight_id])
  @@index([wallet_id])
}

model IncomeTemplate {
  id                       Int      @id @default(autoincrement())
  name                     String
  suggested_amount         Decimal? @db.Decimal(10, 2)
  source                   String?
  applies_first_fortnight  Boolean  @default(false)
  applies_second_fortnight Boolean  @default(false)
  active                   Boolean  @default(true)

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())

  // Relationships
  incomes Income[]
  user    User?    @relation(fields: [user_id], references: [id])
  house   House?   @relation(fields: [house_id], references: [id])

  @@index([user_id])
  @@index([house_id])
}

model House {
  id       Int    @id @default(autoincrement())
  name     String
  owner_id Int?

  created_at DateTime @default(now())

  // Relationships
  owner            User?             @relation(fields: [owner_id], references: [id])
  members          HouseMember[]
  fortnights       Fortnight[]
  expenses         Expense[]
  expenseTemplates ExpenseTemplate[]
  wallets          Wallet[]
  transfersIn      Transfer[]
  incomes          Income[]
  incomeTemplates  IncomeTemplate[]
  categories       Category[]

  creditCardPayments            CreditCardPayment[]
  budgets                       Budget[]
  credit_card_statement_imports CreditCardStatementImport[] @relation("CreditCardStatementImportHouseOwner")
  pantry_receipts               PantryReceipt[]             @relation("PantryReceiptHouseOwner")
  pantry_products               PantryProduct[]             @relation("PantryProductHouseOwner")
  pantry_shopping_carts         PantryShoppingCart[]        @relation("PantryShoppingCartHouseOwner")
  task_lists                    TaskList[]                  @relation("TaskListHouseOwner")
  habits                        Habit[]                     @relation("HabitHouseOwner")
  routines                      Routine[]                   @relation("RoutineHouseOwner")
}

model HouseMember {
  id       Int       @id @default(autoincrement())
  house_id Int
  user_id  Int
  role     HouseRole @default(MEMBER)

  created_at DateTime @default(now())

  // Relationships
  house House @relation(fields: [house_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id])
}

model Wallet {
  id                Int               @id @default(autoincrement())
  name              String
  description       String?
  provider_icon_key String?
  amount            Decimal           @default(0) @db.Decimal(10, 2)
  credit_limit      Decimal?          @db.Decimal(10, 2)
  type              PaymentMethodType
  cutoff_day        Int?
  due_day           Int?
  active            Boolean           @default(true)
  last_paid_period  String?

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())

  // Relationships
  user  User?  @relation(fields: [user_id], references: [id])
  house House? @relation(fields: [house_id], references: [id])

  expenses                      Expense[]
  expense_templates             ExpenseTemplate[]
  incomes                       Income[]
  credit_card_payments          CreditCardPayment[]         @relation("CreditCardWalletPayments")
  source_card_payments          CreditCardPayment[]         @relation("CreditCardSourceWalletPayments")
  credit_card_statement_imports CreditCardStatementImport[]
  budgetAllocations             BudgetAllocation[]

  @@index([user_id])
  @@index([house_id])
  @@index([user_id, type, active])
  @@index([house_id, type, active])
}

model Budget {
  id           Int             @id @default(autoincrement())
  name         String          @db.VarChar(25)
  total_amount Decimal         @db.Decimal(10, 2)
  frequency    BudgetFrequency
  start_date   DateTime?
  end_date     DateTime?
  active       Boolean         @default(true)

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())

  // Relationships
  user        User?              @relation(fields: [user_id], references: [id])
  house       House?             @relation(fields: [house_id], references: [id])
  allocations BudgetAllocation[]

  @@index([user_id])
  @@index([house_id])
}

model BudgetAllocation {
  id          Int     @id @default(autoincrement())
  budget_id   Int
  wallet_id   Int
  category_id Int
  amount      Decimal @db.Decimal(10, 2)

  created_at DateTime @default(now())

  // Relationships
  budget   Budget   @relation(fields: [budget_id], references: [id], onDelete: Cascade)
  wallet   Wallet   @relation(fields: [wallet_id], references: [id])
  category Category @relation(fields: [category_id], references: [id])

  @@index([budget_id])
  @@index([wallet_id])
  @@index([category_id])
}

/**
 * =========================
 * TRANSFERS
 * =========================
 */

model Transfer {
  id       Int          @id @default(autoincrement())
  amount   Decimal      @db.Decimal(10, 2)
  type     TransferType
  user_id  Int
  house_id Int
  note     String?

  created_at DateTime @default(now())

  // Optional links to accounting entries created from this transfer
  user_expense_id Int? @unique
  house_income_id Int? @unique

  user_expense Expense? @relation("TransferUserExpense", fields: [user_expense_id], references: [id])
  house_income Income?  @relation("TransferHouseIncome", fields: [house_income_id], references: [id])

  user  User  @relation(fields: [user_id], references: [id])
  house House @relation(fields: [house_id], references: [id])

  @@index([user_id])
  @@index([house_id])
  @@index([created_at])
}

model CreditCardPayment {
  id                    Int      @id @default(autoincrement())
  amount                Decimal  @db.Decimal(10, 2)
  paid_at               DateTime
  note                  String?
  credit_card_wallet_id Int
  source_wallet_id      Int
  user_id               Int?
  house_id              Int?
  expense_id            Int?     @unique
  created_at            DateTime @default(now())

  credit_card_wallet Wallet   @relation("CreditCardWalletPayments", fields: [credit_card_wallet_id], references: [id])
  source_wallet      Wallet   @relation("CreditCardSourceWalletPayments", fields: [source_wallet_id], references: [id])
  user               User?    @relation(fields: [user_id], references: [id])
  house              House?   @relation(fields: [house_id], references: [id])
  expense            Expense? @relation(fields: [expense_id], references: [id], onDelete: SetNull)

  @@index([credit_card_wallet_id, paid_at])
  @@index([source_wallet_id, paid_at])
  @@index([user_id, paid_at])
  @@index([house_id, paid_at])
}

/**
 * Pantry / grocery receipts (per user or per house), with line items parsed from uploads.
 */
/**
 * Uploaded issuer PDFs (per card). Parsed rows become Expense rows linked via statement_import_id.
 * Provider-specific parsers (e.g. Mercado Pago) live in server code.
 */
model CreditCardStatementImport {
  id                 Int                     @id @default(autoincrement())
  provider           StatementImportProvider
  wallet_id          Int
  user_id            Int?
  house_id           Int?
  created_by_user_id Int

  file_name String?
  file_mime String?
  file_data Bytes?

  period_start         DateTime?
  period_end           DateTime?
  account_number       String?
  statement_issue_date DateTime?
  payment_due_date     DateTime?
  total_due            Decimal?  @db.Decimal(12, 2)
  minimum_payment      Decimal?  @db.Decimal(12, 2)

  parse_warnings String[] @default([])

  created_at DateTime @default(now())

  wallet     Wallet    @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  user       User?     @relation("CreditCardStatementImportUserOwner", fields: [user_id], references: [id])
  house      House?    @relation("CreditCardStatementImportHouseOwner", fields: [house_id], references: [id])
  created_by User      @relation("CreditCardStatementImportCreatedBy", fields: [created_by_user_id], references: [id])
  expenses   Expense[]

  @@index([wallet_id])
  @@index([user_id])
  @@index([house_id])
  @@index([created_at])
}

model PantryReceipt {
  id             Int            @id @default(autoincrement())
  title          String?
  /**
   * Optional totals parsed from receipt footer (e.g. Subtotal, Total).
   */
  subtotal       Decimal?       @db.Decimal(12, 2)
  discount_total Decimal?       @db.Decimal(12, 2)
  delivery_fee   Decimal?       @db.Decimal(12, 2)
  grand_total    Decimal?       @db.Decimal(12, 2)
  merchant_ref   String?
  currency       String         @default("MXN")
  purchased_at   DateTime?
  store          ShoppingStore?
  source_type    String?
  linked_cart_id Int?

  user_id  Int?
  house_id Int?

  created_by_user_id Int

  file_name String?
  file_mime String?
  file_data Bytes?

  parse_warnings String[] @default([])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User?               @relation("PantryReceiptUserOwner", fields: [user_id], references: [id])
  house      House?              @relation("PantryReceiptHouseOwner", fields: [house_id], references: [id])
  created_by User                @relation("PantryReceiptCreatedBy", fields: [created_by_user_id], references: [id])
  lines      PantryReceiptLine[]
  linked_cart PantryShoppingCart? @relation(fields: [linked_cart_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([house_id])
  @@index([created_at])
  @@index([linked_cart_id])
}

model PantryReceiptLine {
  id          Int      @id @default(autoincrement())
  receipt_id  Int
  sort_order  Int      @default(0)
  description String
  normalized_name String?
  quantity    Decimal  @default(1) @db.Decimal(14, 4)
  /// Unit shown on receipt (pz, kg, etc.)
  unit_label  String?
  normalized_unit String?
  unit_price  Decimal? @db.Decimal(12, 2)
  line_total  Decimal  @db.Decimal(12, 2)

  receipt PantryReceipt @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@index([receipt_id])
}

/**
 * Pantry product catalog (per user or house) for reference prices and labels.
 */
model PantryProduct {
  id                 Int      @id @default(autoincrement())
  name               String
  normalized_name    String?
  description        String?
  barcode            String?
  brand              String?
  /// Default unit (pz, kg, L, etc.)
  unit_label         String?
  normalized_unit    String?
  default_unit_price Decimal? @db.Decimal(12, 2)
  active             Boolean  @default(true)

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user  User?  @relation("PantryProductUserOwner", fields: [user_id], references: [id])
  house House? @relation("PantryProductHouseOwner", fields: [house_id], references: [id])

  shopping_items PantryShoppingCartItem[]

  @@index([user_id])
  @@index([house_id])
}

/**
 * Pre-shopping "to-buy" list. Owned by a user or a house; every house member
 * can see and mutate the cart and its items. Cart mutations append to the
 * activity log for audit / "who did what".
 */
model PantryShoppingCart {
  id       Int                @id @default(autoincrement())
  title    String
  notes    String?
  status   ShoppingCartStatus @default(IN_PROGRESS)
  currency String             @default("MXN")
  store    ShoppingStore?

  user_id  Int?
  house_id Int?

  created_by_user_id Int
  updated_by_user_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User?  @relation("PantryShoppingCartUserOwner", fields: [user_id], references: [id])
  house      House? @relation("PantryShoppingCartHouseOwner", fields: [house_id], references: [id])
  created_by User   @relation("PantryShoppingCartCreatedBy", fields: [created_by_user_id], references: [id])
  updated_by User?  @relation("PantryShoppingCartUpdatedBy", fields: [updated_by_user_id], references: [id])

  items      PantryShoppingCartItem[]
  activities PantryShoppingCartActivity[]

  @@index([user_id])
  @@index([house_id])
  @@index([status])
  @@index([created_at])
}

model PantryShoppingCartItem {
  id         Int      @id @default(autoincrement())
  cart_id    Int
  product_id Int?
  /// Snapshot of the product name (or ad-hoc text). Kept independent so renaming
  /// a catalog product doesn't rewrite history.
  name       String
  quantity   Decimal  @default(1) @db.Decimal(14, 4)
  unit_label String?
  unit_price Decimal? @db.Decimal(12, 2)
  notes      String?
  checked    Boolean  @default(false)
  sort_order Int      @default(0)

  created_by_user_id Int
  updated_by_user_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  cart       PantryShoppingCart @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product    PantryProduct?     @relation(fields: [product_id], references: [id], onDelete: SetNull)
  created_by User               @relation("PantryShoppingCartItemCreatedBy", fields: [created_by_user_id], references: [id])
  updated_by User?              @relation("PantryShoppingCartItemUpdatedBy", fields: [updated_by_user_id], references: [id])

  @@index([cart_id])
  @@index([product_id])
}

/**
 * Append-only activity log for a shopping cart. item_id is stored as a scalar
 * (no FK) so removed-item events survive the cascade when the item is deleted.
 */
model PantryShoppingCartActivity {
  id       Int                        @id @default(autoincrement())
  cart_id  Int
  item_id  Int?
  user_id  Int
  action   ShoppingCartActivityAction
  metadata Json?

  created_at DateTime @default(now())

  cart PantryShoppingCart @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  user User               @relation("PantryShoppingCartActivityUser", fields: [user_id], references: [id])

  @@index([cart_id, created_at])
  @@index([item_id])
}

model TaskList {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  color       String?
  archived    Boolean @default(false)

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user  User?  @relation("TaskListUserOwner", fields: [user_id], references: [id])
  house House? @relation("TaskListHouseOwner", fields: [house_id], references: [id])

  items TaskItem[]

  @@index([user_id, archived])
  @@index([house_id, archived])
  @@index([created_at])
}

model TaskItem {
  id                Int             @id @default(autoincrement())
  list_id           Int
  title             String
  notes             String?
  status            TaskStatus      @default(TODO)
  priority          TaskPriority    @default(MEDIUM)
  due_at            DateTime?
  completed_at      DateTime?
  recurrence_unit   RecurrenceUnit?
  recurrence_every  Int?
  recurrence_anchor DateTime?
  sort_order        Int             @default(0)

  created_by_user_id Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  list       TaskList @relation(fields: [list_id], references: [id], onDelete: Cascade)
  created_by User     @relation("TaskItemCreatedBy", fields: [created_by_user_id], references: [id])

  @@index([list_id, status])
  @@index([list_id, due_at])
  @@index([list_id, sort_order])
}

model Habit {
  id                Int            @id @default(autoincrement())
  name              String
  description       String?
  active            Boolean        @default(true)
  recurrence_unit   RecurrenceUnit
  recurrence_every  Int            @default(1)
  target_per_period Int            @default(1)
  reminder_time     String?

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user  User?  @relation("HabitUserOwner", fields: [user_id], references: [id])
  house House? @relation("HabitHouseOwner", fields: [house_id], references: [id])

  logs HabitLog[]

  @@index([user_id, active])
  @@index([house_id, active])
  @@index([created_at])
}

model HabitLog {
  id                   Int      @id @default(autoincrement())
  habit_id             Int
  completed_on         DateTime
  note                 String?
  completed_by_user_id Int?

  created_at DateTime @default(now())

  habit        Habit @relation(fields: [habit_id], references: [id], onDelete: Cascade)
  completed_by User? @relation("HabitLogCompletedBy", fields: [completed_by_user_id], references: [id])

  @@unique([habit_id, completed_on])
  @@index([habit_id, completed_on])
}

model Routine {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  time_of_day RoutineTimeOfDay @default(CUSTOM)
  active_days Int[]            @default([])
  active      Boolean          @default(true)

  user_id  Int?
  house_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user  User?  @relation("RoutineUserOwner", fields: [user_id], references: [id])
  house House? @relation("RoutineHouseOwner", fields: [house_id], references: [id])

  steps RoutineStep[]
  runs  RoutineRun[]

  @@index([user_id, active])
  @@index([house_id, active])
  @@index([created_at])
}

model RoutineStep {
  id          Int     @id @default(autoincrement())
  routine_id  Int
  title       String
  description String?
  sort_order  Int     @default(0)
  is_optional Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  routine Routine @relation(fields: [routine_id], references: [id], onDelete: Cascade)

  @@index([routine_id, sort_order])
}

model RoutineRun {
  id                   Int      @id @default(autoincrement())
  routine_id           Int
  run_on               DateTime
  completed_steps      Int      @default(0)
  total_steps          Int      @default(0)
  completed            Boolean  @default(false)
  completed_by_user_id Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  routine      Routine @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  completed_by User?   @relation("RoutineRunCompletedBy", fields: [completed_by_user_id], references: [id])

  @@unique([routine_id, run_on])
  @@index([routine_id, run_on])
}
