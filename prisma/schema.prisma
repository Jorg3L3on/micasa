// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum PaymentMethodType {
  CARD
  CASH
}

enum CategoryGroup {
  FIXED
  VARIABLE
  SAVINGS
}

enum FortnightPeriod {
  FIRST // 1–15
  SECOND // 16–end of month
}

// 1. Users - Represents the people involved in the budget (kept for backward compatibility, not actively used)
model User {
  id         Int      @id @default(autoincrement())
  name       String
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  // Relationships
  summaries UserFortnightSummary[]
  income    FortnightIncome[]

  @@unique([name])
  @@index([active])
}

// 2. Fortnights - Represents each budgeting period
model Fortnight {
  id         Int             @id @default(autoincrement())
  start_date DateTime
  end_date   DateTime
  label      String
  month      Int
  year       Int
  period     FortnightPeriod
  closed     Boolean         @default(false)
  created_at DateTime        @default(now())

  // Relationships
  expenses    Expense[]
  income      FortnightIncome[]
  allocations FortnightAllocation[]
  balances    FortnightBalance?
  summaries   UserFortnightSummary[]

  @@unique([year, month, period])
  @@index([year, month])
  @@index([closed])
}

// 3. Payment Methods - Represents how something is paid
model PaymentMethod {
  id         Int               @id @default(autoincrement())
  name       String // Tarjeta, Efectivo
  type       PaymentMethodType
  created_at DateTime          @default(now())

  // Relationships
  cards Card[]

  @@unique([name])
}

// 4. Cards - Represents credit/debit cards (no longer tied to users)
model Card {
  id                Int      @id @default(autoincrement())
  name              String // e.g., Liverpool Jorge, AT&T Carmen
  payment_method_id Int
  active            Boolean  @default(true)
  created_at        DateTime @default(now())

  // Relationships
  payment_method    PaymentMethod     @relation(fields: [payment_method_id], references: [id])
  expenses          Expense[]
  expense_templates ExpenseTemplate[]

  @@unique([name])
  @@index([active])
}

// 5. Categories - Represents what the expense is for
model Category {
  id         Int            @id @default(autoincrement())
  name       String
  group      CategoryGroup? // Optional: FIXED, VARIABLE, SAVINGS
  created_at DateTime       @default(now())

  // Relationships
  expenses          Expense[]
  allocations       FortnightAllocation[]
  expense_templates ExpenseTemplate[]

  @@unique([name])
  @@index([group])
}

// Expense Templates - Reusable expense templates
model ExpenseTemplate {
  id                       Int      @id @default(autoincrement())
  name                     String // Renta, TELMEX, AT&T Jorge, etc.
  category_id              Int
  default_card_id          Int? // Nullable
  suggested_amount         Decimal? @db.Decimal(10, 2)
  is_recurring             Boolean  @default(false)
  applies_first_fortnight  Boolean  @default(false)
  applies_second_fortnight Boolean  @default(false)
  active                   Boolean  @default(true)
  created_at               DateTime @default(now())

  // Relationships
  category     Category  @relation(fields: [category_id], references: [id])
  default_card Card?     @relation(fields: [default_card_id], references: [id])
  expenses     Expense[]

  @@unique([name])
  @@index([category_id])
  @@index([default_card_id])
  @@index([active])
}

// 6. Expenses - Core transactional table (each row in your left tables)
model Expense {
  id                  Int       @id @default(autoincrement())
  fortnight_id        Int
  card_id             Int? // Nullable for cash
  category_id         Int
  expense_template_id Int? // Nullable
  description         String // e.g., Liverpool Jorge, TELMEX
  amount              Decimal   @db.Decimal(10, 2)
  is_paid             Boolean   @default(false)
  payment_date        DateTime?
  created_at          DateTime  @default(now())

  // Relationships
  fortnight        Fortnight        @relation(fields: [fortnight_id], references: [id])
  card             Card?            @relation(fields: [card_id], references: [id])
  category         Category         @relation(fields: [category_id], references: [id])
  expense_template ExpenseTemplate? @relation(fields: [expense_template_id], references: [id])

  @@index([fortnight_id])
  @@index([card_id])
  @@index([category_id])
  @@index([is_paid])
}

// 7. Fortnight Income - Represents "Tenemos" (how much money exists for the fortnight)
model FortnightIncome {
  id           Int      @id @default(autoincrement())
  fortnight_id Int
  user_id      Int
  amount       Decimal  @db.Decimal(10, 2)
  source       String? // Salary, Transfer, __OVERRIDE__, etc.
  created_at   DateTime @default(now())

  // Relationships
  fortnight Fortnight @relation(fields: [fortnight_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id])

  @@index([fortnight_id])
  @@index([user_id])
}

// 8. Fortnight Allocations - Represents planned spending or saving
model FortnightAllocation {
  id           Int      @id @default(autoincrement())
  fortnight_id Int
  category_id  Int
  amount       Decimal  @db.Decimal(10, 2)
  notes        String?
  created_at   DateTime @default(now())

  // Relationships
  fortnight Fortnight @relation(fields: [fortnight_id], references: [id])
  category  Category  @relation(fields: [category_id], references: [id])

  @@unique([fortnight_id, category_id])
  @@index([fortnight_id])
  @@index([category_id])
}

// 9. Fortnight Balances - Stores snapshots of calculated totals
model FortnightBalance {
  id             Int      @id @default(autoincrement())
  fortnight_id   Int      @unique
  total_income   Decimal  @db.Decimal(10, 2)
  total_expenses Decimal  @db.Decimal(10, 2)
  total_paid     Decimal  @db.Decimal(10, 2)
  total_unpaid   Decimal  @db.Decimal(10, 2)
  remaining      Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now())

  // Relationships
  fortnight Fortnight @relation(fields: [fortnight_id], references: [id])
}

// 10. User Fortnight Summary - Represents per-user splits
model UserFortnightSummary {
  id             Int      @id @default(autoincrement())
  fortnight_id   Int
  user_id        Int
  total_income   Decimal  @db.Decimal(10, 2)
  total_expenses Decimal  @db.Decimal(10, 2)
  paid           Decimal  @db.Decimal(10, 2)
  unpaid         Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now())

  // Relationships
  fortnight Fortnight @relation(fields: [fortnight_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id])

  @@unique([fortnight_id, user_id])
  @@index([fortnight_id])
  @@index([user_id])
}
